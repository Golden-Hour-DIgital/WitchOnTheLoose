# ─── Supabase ───────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Square ─────────────────────────────────────
# Get these from: https://developer.squareup.com/apps
NEXT_PUBLIC_SQUARE_APP_ID=sandbox-sq0idb-...
NEXT_PUBLIC_SQUARE_LOCATION_ID=your-location-id
NEXT_PUBLIC_SQUARE_ENV=sandbox                  # 'sandbox' or 'production'
SQUARE_ACCESS_TOKEN=EAAAl...                    # Server-side only
SQUARE_API_BASE_URL=https://connect.squareupsandbox.com  # or https://connect.squareup.com

# ─── Resend (email) ──────────────────────────────
# Get from: https://resend.com
RESEND_API_KEY=re_...

# ─── Admin Access ────────────────────────────────
# Comma-separated emails allowed to sign into /admin
ADMIN_EMAILS=shannon@witchontheloose.com

# Public URL of the site (used for magic-link redirect)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
